<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions xmlns:dmn="https://www.omg.org/spec/DMN/20191111/MODEL/"
             namespace="http://www.flowable.org/dmn"
             name="Card Limit Check">

  <dmn:decision id="card-limit-check" name="Card Limit Check">
    <dmn:decisionTable id="cardLimitCheckTable" hitPolicy="FIRST">

      <dmn:input id="input_requestedLimit" label="Requested Limit">
        <dmn:inputExpression id="inputExpr_requestedLimit" typeRef="number">
          <dmn:text>requestedLimit</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:input id="input_creditScore" label="Credit Score">
        <dmn:inputExpression id="inputExpr_creditScore" typeRef="number">
          <dmn:text>creditScore</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:output id="output_approvedLimit" label="Approved Limit" typeRef="number" />

      <!-- Rule 1: creditScore >= 700 -> requestedLimit -->
      <dmn:rule id="rule1">
        <dmn:inputEntry id="inputEntry1_1"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry1_2"><dmn:text>&gt;= 700</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry1_1"><dmn:text>requestedLimit</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 2: creditScore 600-699 -> min(requestedLimit, 10000) -->
      <dmn:rule id="rule2">
        <dmn:inputEntry id="inputEntry2_1"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry2_2"><dmn:text>&gt;= 600 &amp;&amp; &lt; 700</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry2_1"><dmn:text>#{requestedLimit &lt; 10000 ? requestedLimit : 10000}</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 3: creditScore < 600 -> 5000 -->
      <dmn:rule id="rule3">
        <dmn:inputEntry id="inputEntry3_1"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry3_2"><dmn:text>&lt; 600</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry3_1"><dmn:text>5000</dmn:text></dmn:outputEntry>
      </dmn:rule>

    </dmn:decisionTable>
  </dmn:decision>

</dmn:definitions>
