<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions xmlns:dmn="https://www.omg.org/spec/DMN/20191111/MODEL/"
             id="travelCheckDefinitions" name="Travel Check">

  <dmn:decision id="travel-check" name="Travel Check">
    <dmn:decisionTable id="travelCheckTable" hitPolicy="FIRST">

      <dmn:input id="input_hasTravel" label="Has Travel">
        <dmn:inputExpression id="inputExpr_hasTravel" typeRef="boolean">
          <dmn:text>hasTravel</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:input id="input_amount" label="Amount">
        <dmn:inputExpression id="inputExpr_amount" typeRef="number">
          <dmn:text>amount</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:output id="output_approvalPath" label="Approval Path" name="approvalPath" typeRef="string" />

      <!-- Rule 1: No travel -> STANDARD -->
      <dmn:rule id="rule1">
        <dmn:inputEntry id="inputEntry1_1">
          <dmn:text>false</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="inputEntry1_2">
          <dmn:text></dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="outputEntry1_1">
          <dmn:text>"STANDARD"</dmn:text>
        </dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 2: Travel AND amount <= 10000 -> STANDARD -->
      <dmn:rule id="rule2">
        <dmn:inputEntry id="inputEntry2_1">
          <dmn:text>true</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="inputEntry2_2">
          <dmn:text>&lt;= 10000</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="outputEntry2_1">
          <dmn:text>"STANDARD"</dmn:text>
        </dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 3: Travel AND amount > 10000 -> DIRECTOR -->
      <dmn:rule id="rule3">
        <dmn:inputEntry id="inputEntry3_1">
          <dmn:text>true</dmn:text>
        </dmn:inputEntry>
        <dmn:inputEntry id="inputEntry3_2">
          <dmn:text>&gt; 10000</dmn:text>
        </dmn:inputEntry>
        <dmn:outputEntry id="outputEntry3_1">
          <dmn:text>"DIRECTOR"</dmn:text>
        </dmn:outputEntry>
      </dmn:rule>

    </dmn:decisionTable>
  </dmn:decision>

</dmn:definitions>
