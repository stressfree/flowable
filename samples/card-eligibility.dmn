<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions xmlns:dmn="https://www.omg.org/spec/DMN/20191111/MODEL/"
             namespace="http://www.flowable.org/dmn"
             name="Card Eligibility">

  <dmn:decision id="card-eligibility" name="Card Eligibility">
    <dmn:decisionTable id="cardEligibilityTable" hitPolicy="FIRST">

      <dmn:input id="input_empStatus" label="Employee Status">
        <dmn:inputExpression id="inputExpr_empStatus" typeRef="string">
          <dmn:text>employeeStatus</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:input id="input_existingCards" label="Existing Cards">
        <dmn:inputExpression id="inputExpr_existingCards" typeRef="number">
          <dmn:text>existingCards</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:input id="input_requestedLimit" label="Requested Limit">
        <dmn:inputExpression id="inputExpr_requestedLimit" typeRef="number">
          <dmn:text>requestedLimit</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:output id="output_eligible" label="Eligible" typeRef="boolean" />

      <!-- Rule 1: INACTIVE -> false -->
      <dmn:rule id="rule1">
        <dmn:inputEntry id="inputEntry1_1"><dmn:text>== 'INACTIVE'</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry1_2"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry1_3"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry1_1"><dmn:text>false</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 2: ACTIVE AND existingCards >= 3 -> false -->
      <dmn:rule id="rule2">
        <dmn:inputEntry id="inputEntry2_1"><dmn:text>== 'ACTIVE'</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry2_2"><dmn:text>&gt;= 3</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry2_3"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry2_1"><dmn:text>false</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 3: ACTIVE AND existingCards < 3 AND requestedLimit <= 25000 -> true -->
      <dmn:rule id="rule3">
        <dmn:inputEntry id="inputEntry3_1"><dmn:text>== 'ACTIVE'</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry3_2"><dmn:text>&lt; 3</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry3_3"><dmn:text>&lt;= 25000</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry3_1"><dmn:text>true</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 4: else -> false -->
      <dmn:rule id="rule4">
        <dmn:inputEntry id="inputEntry4_1"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry4_2"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry4_3"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry4_1"><dmn:text>false</dmn:text></dmn:outputEntry>
      </dmn:rule>

    </dmn:decisionTable>
  </dmn:decision>

</dmn:definitions>
