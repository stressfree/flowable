<?xml version="1.0" encoding="UTF-8"?>
<dmn:definitions xmlns:dmn="https://www.omg.org/spec/DMN/20191111/MODEL/"
             namespace="http://www.flowable.org/dmn"
             name="Card Control Thresholds">

  <dmn:decision id="card-control-thresholds" name="Card Control Thresholds">
    <dmn:decisionTable id="cardControlThresholdsTable" hitPolicy="FIRST">

      <dmn:input id="input_amount" label="Amount">
        <dmn:inputExpression id="inputExpr_amount" typeRef="number">
          <dmn:text>amount</dmn:text>
        </dmn:inputExpression>
      </dmn:input>
      <dmn:input id="input_changeType" label="Change Type">
        <dmn:inputExpression id="inputExpr_changeType" typeRef="string">
          <dmn:text>changeType</dmn:text>
        </dmn:inputExpression>
      </dmn:input>

      <dmn:output id="output_approvalLevel" label="Approval Level" typeRef="string" />

      <!-- Rule 1: LIMIT_DECREASE -> AUTO -->
      <dmn:rule id="rule1">
        <dmn:inputEntry id="inputEntry1_1"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry1_2"><dmn:text>== 'LIMIT_DECREASE'</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry1_1"><dmn:text>'AUTO'</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 2: FREEZE -> AUTO -->
      <dmn:rule id="rule2">
        <dmn:inputEntry id="inputEntry2_1"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry2_2"><dmn:text>== 'FREEZE'</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry2_1"><dmn:text>'AUTO'</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 3: UNFREEZE -> AUTO -->
      <dmn:rule id="rule3">
        <dmn:inputEntry id="inputEntry3_1"><dmn:text></dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry3_2"><dmn:text>== 'UNFREEZE'</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry3_1"><dmn:text>'AUTO'</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 4: LIMIT_INCREASE < 1000 -> AUTO -->
      <dmn:rule id="rule4">
        <dmn:inputEntry id="inputEntry4_1"><dmn:text>&lt; 1000</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry4_2"><dmn:text>== 'LIMIT_INCREASE'</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry4_1"><dmn:text>'AUTO'</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 5: LIMIT_INCREASE 1000-5000 -> MANAGER -->
      <dmn:rule id="rule5">
        <dmn:inputEntry id="inputEntry5_1"><dmn:text>&gt;= 1000 &amp;&amp; &lt;= 5000</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry5_2"><dmn:text>== 'LIMIT_INCREASE'</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry5_1"><dmn:text>'MANAGER'</dmn:text></dmn:outputEntry>
      </dmn:rule>

      <!-- Rule 6: LIMIT_INCREASE > 5000 -> DUAL -->
      <dmn:rule id="rule6">
        <dmn:inputEntry id="inputEntry6_1"><dmn:text>&gt; 5000</dmn:text></dmn:inputEntry>
        <dmn:inputEntry id="inputEntry6_2"><dmn:text>== 'LIMIT_INCREASE'</dmn:text></dmn:inputEntry>
        <dmn:outputEntry id="outputEntry6_1"><dmn:text>'DUAL'</dmn:text></dmn:outputEntry>
      </dmn:rule>

    </dmn:decisionTable>
  </dmn:decision>

</dmn:definitions>
