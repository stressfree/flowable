{
  "request": {
    "method": "POST",
    "url": "/cards/apply-changes"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "status": "success",
      "mock": true,
      "receivedAt": "{{now}}",
      "data": {
        "changeId": "chg-{{$random.uuid}}",
        "applied": true,
        "message": "Card control changes applied successfully"
      }
    },
    "fixedDelayMilliseconds": 200
  }
}
