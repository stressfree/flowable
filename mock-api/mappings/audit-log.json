{
  "request": {
    "method": "POST",
    "url": "/audit/log"
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "status": "success",
      "mock": true,
      "receivedAt": "{{now}}",
      "data": {
        "logId": "log-{{$random.uuid}}",
        "logged": true,
        "message": "Audit entry recorded successfully"
      }
    },
    "fixedDelayMilliseconds": 200
  }
}
